<Window x:Class="DiamondSword.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:DiamondSword.Resources"
        Title="Matchblox" MinHeight="450" MinWidth="500" Height="500" Width="800" ResizeMode="CanResize">


    <Window.Resources>
        <!-- Fonts -->
        <FontFamily x:Key="base">pack://application:,,,/DiamondSword;component/fonts/#Inter</FontFamily>
        <FontFamily x:Key="minecraft">pack://application:,,,/DiamondSword;component/fonts/#Monocraft</FontFamily>

        <!-- Accent Colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="DarkGreen"/>
        <SolidColorBrush x:Key="AccentBrushHover" Color="Green"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#E0E3EB"/>
        <SolidColorBrush x:Key="ShadowBrush" Color="#22000000"/>

        <!-- Modern Button Style -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource base}"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrushHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBlocks -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource base}"/>
            <Setter Property="Foreground" Value="#222"/>
        </Style>

        <!-- TextBoxes -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource base}"/>
            <Setter Property="Background" Value="#F3F5F8"/>
            <Setter Property="BorderBrush" Value="#D0D4DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>


    </Window.Resources>

    <Grid Margin="17,8,8,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left control panel -->
        <Border Background="{StaticResource PanelBrush}"
                CornerRadius="10"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                Padding="16"
                Effect="{DynamicResource ShadowEffect}">

            <!-- Left control panel -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top" >

                <!-- R -->
                <TextBlock FontWeight="Bold" FontSize="14" Text="{x:Static resx:Resources.Label_ColorRGB}" Width="79"/>

                <!-- R -->
                <TextBlock Text="{x:Static resx:Resources.Label_R}" Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="SliderR" Minimum="0" Maximum="255" Width="170" ValueChanged="RgbSlider_ValueChanged"/>
                    <TextBox x:Name="TxtR" Width="36"  Background="Transparent" IsReadOnly="True" Margin="6,0,0,0" TextAlignment="Center"/>
                </StackPanel>

                <!-- G -->
                <TextBlock Text="{x:Static resx:Resources.Label_G}" Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="SliderG"  Minimum="0" Maximum="255" Width="170" ValueChanged="RgbSlider_ValueChanged"/>
                    <TextBox x:Name="TxtG" Width="36"  Background="Transparent" IsReadOnly="True" Margin="6,0,0,0" TextAlignment="Center"/>
                </StackPanel>

                <!-- B -->
                <TextBlock Text="{x:Static resx:Resources.Label_B}" Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="SliderB" Minimum="0"  Maximum="255" Width="170" ValueChanged="RgbSlider_ValueChanged"/>
                    <TextBox x:Name="TxtB" Width="36"  Background="Transparent" IsReadOnly="True" Margin="6,0,0,0" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Border x:Name="ColorPreview" Width="96" Height="40" BorderBrush="LightGray" BorderThickness="1" PreviewMouseLeftButtonDown="BtnPickColor_Click"/>
                    <!-- Block amount -->
                    <Separator Width="12" Visibility="Hidden"/>
                    <StackPanel Orientation="Vertical" >
                        <TextBlock Text="{x:Static resx:Resources.Label_BlocksToShow}" Margin="0,0,0,4"/>

                        <TextBox x:Name="TxtAmount" Width="80" TextChanged="BtnApplyAmount_Click" Text="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Alpha filter -->
                <TextBlock Text="{x:Static resx:Resources.Label_AlphaFilter}" Margin="0,12,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="SliderAlpha" Minimum="0" Maximum="1" Value="0" SmallChange="0.01" LargeChange="0.1" TickFrequency="0.1" IsSnapToTickEnabled="False" Width="170" ValueChanged="AlphaSlider_ValueChanged"/>
                    <TextBlock x:Name="TxtAlpha" Width="60" Text="0.00" Margin="6,0,0,0" VerticalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>



                <!-- Import / Display buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button x:Name="BtnImport" Content="{x:Static resx:Resources.Button_ImportTextures}" Click="BtnImport_Click" Width="121" Height="25" Margin="0,4,0,4"/>
                    <Button x:Name="BtnDisplay" Content="{x:Static resx:Resources.Button_Refresh}" Click="BtnDisplay_Click" Margin="8,0,0,0" Width="74" Height="25"/>
                </StackPanel>

                <TextBlock Text="{x:Static resx:Resources.Instruction_ClickItem}" TextWrapping="Wrap" Margin="0,12,0,0" FontSize="11"/>
            </StackPanel>
        </Border>


        <Separator Grid.Column="1" Margin="0,0" VerticalAlignment="Stretch" Visibility="Hidden"/>

        <!-- Right: block display -->
        <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="10" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">

            <ListBox x:Name="ListBlocks"
         Grid.Column="2"
         BorderThickness="0"
         SelectionMode="Single"
         MouseDoubleClick="ListBlocks_MouseDoubleClick"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel UseLayoutRounding="True" SnapsToDevicePixels="True" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6" Width="120" Height="120"
                    BorderBrush="Gray" BorderThickness="0" Padding="10">
                            <StackPanel>
                                <Image 
                        Source="{Binding Icon}" 
                        Width="96" Height="96"
                        Stretch="Uniform"
                        SnapsToDevicePixels="True"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                ToolTip="{Binding DisplayName}"/>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>


    </Grid>
</Window>
